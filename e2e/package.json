{
	"name": "e2e",
	"version": "0.0.1",
	"scripts": {
		"e2e:gen": "npx playwright codegen -b firefox govhub.data-hub.local --ignore-https-errors",
		"lint:fix": "eslint --max-warnings 0 --fix --cache test",
		"lint:check": "eslint --max-warnings 0 --cache test"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "3.1044.0",
		"@aws-sdk/client-sts": "3.1044.0",
		"@aws-sdk/lib-storage": "3.1044.0",
		"@playwright/test": "1.59.1",
		"axios": "1.16.0",
		"libqp": "2.1.1",
		"mqtt": "5.15.1",
		"playwright": "1.59.1",
		"sharp": "0.34.5"
	},
	"devDependencies": {
		"@eslint/eslintrc": "3.3.5",
		"@eslint/js": "9.39.4",
		"@types/libqp": "1.1.3",
		"@types/node": "24.12.2",
		"@typescript-eslint/eslint-plugin": "8.59.2",
		"@typescript-eslint/parser": "8.59.2",
		"eslint": "9.39.4"
	},
	"keywords": [],
	"author": "",
	"lint-staged": {
		"*.{js,ts}": [
			"eslint --cache --fix",
			"../node_modules/.bin/prettier --write"
		],
		"*.nix": "sh -c '{ which alejandra || exit 0 ; } && alejandra \"$@\"' -",
		"*.{cjs,json,css,scss,htm,html,md,yml,yaml}": "../node_modules/.bin/prettier --write",
		"*.sh": "../util/check-whitespace-violations"
	}
}
