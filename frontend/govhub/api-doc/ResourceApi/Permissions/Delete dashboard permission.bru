  url: {{keycloak-host}}/realms/{{realm}}/data-hub/tenants/{{tenant}}/viz-groups/{{viz-group}}/dashboards/{{dashboard-name}}/permissions/{{permission}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access-token}}
}

