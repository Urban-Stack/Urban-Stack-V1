meta {
  name: Put dashboard permission
  type: http
  seq: 7
}

put {
  url: {{keycloak-host}}/realms/{{realm}}/data-hub/tenants/{{tenant}}/viz-groups/{{viz-group}}/dashboards/{{dashboard-name}}/permissions/{{permission}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access-token}}
}

body:json {
  {
    "scopes": [
      "dashboard:admin"
    ],
    "principals": [
      {
        "type": "group",
        "tenant": "{{tenant}}",
        "group": "admin"
      }
    ]
  }
}
