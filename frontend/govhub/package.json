{
  "name": "ugh-fe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "preinstall": "sh -c '. ./preinstall.sh'",
    "dev": "sh -c '. ./env.local.sh && next dev'",
    "build": "next build",
    "start": "next start",
    "start:local": "sh -c '. ./env.local.sh && pnpm run start'",
    "lint:check": "next lint --max-warnings 0",
    "lint:fix": "next lint --fix --max-warnings 0",
    "format:check": "prettier --check --ignore-path .gitignore '**/*.{js,mjs,ts,tsx,css,scss,json}'",
    "format:fix": "prettier --write --ignore-path .gitignore '**/*.{js,mjs,ts,tsx,css,scss,json}'",
    "type:check": "tsc --noEmit",
    "test": "jest --coverage=false",
    "test:watch": "jest --watch --coverage=false",
    "test:update-snapshot": "jest --updateSnapshot --coverage=false",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage",
    "gen:graphql:local": "sh -c '. ./env.local.sh && graphql-codegen'",
    "postinstall": "flowbite-react patch"
  },
  "engines": {
    "pnpm": "10",
    "node": ">=18"
  },
  "dependencies": {
    "@apollo/client": "4.1.9",
    "@aws-sdk/client-s3": "3.1044.0",
    "@aws-sdk/client-sts": "3.1044.0",
    "@aws-sdk/s3-presigned-post": "3.1044.0",
    "@aws-sdk/s3-request-presigner": "3.1044.0",
    "@graphql-typed-document-node/core": "3.2.0",
    "@tailwindcss/postcss": "4.2.4",
    "client-only": "0.0.1",
    "flowbite-react": "0.11.9",
    "graphql": "16.14.0",
    "leaflet": "1.9.4",
    "lodash": "4.18.1",
    "next": "15.5.18",
    "next-auth": "5.0.0-beta.31",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-toastify": "11.1.0",
    "server-only": "0.0.1",
    "swr": "2.4.1",
    "tailwind-merge": "3.5.0",
    "udp-ui": "file:./lib/udp-ui",
    "use-debounce": "10.1.1",
    "zod": "3.25.76",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@anatine/zod-mock": "3.14.0",
    "@babel/core": "7.29.0",
    "@eslint/eslintrc": "3.3.5",
    "@faker-js/faker": "10.4.0",
    "@graphql-codegen/cli": "6.3.1",
    "@graphql-codegen/client-preset": "5.3.0",
    "@graphql-codegen/introspection": "5.0.2",
    "@graphql-codegen/typescript": "5.0.10",
    "@graphql-codegen/typescript-operations": "5.1.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "30.0.0",
    "@types/leaflet": "1.9.21",
    "@types/lodash": "4.17.24",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-jest": "30.3.0",
    "eslint": "9.39.4",
    "eslint-config-next": "15.5.16",
    "eslint-plugin-prefer-arrow-functions": "3.9.1",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "jest-junit": "16.0.0",
    "lint-staged": "16.4.0",
    "postcss": "8.5.14",
    "prettier": "3.8.3",
    "tailwindcss": "4.2.4",
    "ts-essentials": "10.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.2"
  }
}
