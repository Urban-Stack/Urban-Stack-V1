{
  "name": "udp-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.es.js",
      "require": "./dist/components.cjs.js"
    },
    "./tailwind-config": {
      "types": "./dist/tailwind.d.ts",
      "import": "./dist/tailwind.es.js",
      "require": "./dist/tailwind.cjs.js"
    },
    "./assertion": {
      "types": "./dist/assertion.d.ts",
      "import": "./dist/assertion.es.js",
      "require": "./dist/assertion.cjs.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "import": "./dist/env.es.js",
      "require": "./dist/env.cjs.js"
    },
    "./fp": {
      "types": "./dist/fp.d.ts",
      "import": "./dist/fp.es.js",
      "require": "./dist/fp.cjs.js"
    },
    "./fetching": {
      "types": "./dist/fetching.d.ts",
      "import": "./dist/fetching.es.js",
      "require": "./dist/fetching.cjs.js"
    },
    "./hook": {
      "types": "./dist/hook.d.ts",
      "import": "./dist/hook.es.js",
      "require": "./dist/hook.cjs.js"
    },
    "./string": {
      "types": "./dist/string.d.ts",
      "import": "./dist/string.es.js",
      "require": "./dist/string.cjs.js"
    },
    "./tailwind": {
      "types": "./dist/tailwind.d.ts",
      "import": "./dist/tailwind.es.js",
      "require": "./dist/tailwind.cjs.js"
    },
    "./test-utils": {
      "types": "./dist/test-utils.d.ts",
      "import": "./dist/test-utils.es.js",
      "require": "./dist/test-utils.cjs.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.es.js",
      "require": "./dist/theme.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format:check": "prettier --check --ignore-path .gitignore '**/*.{js,mjs,ts,tsx,css,scss,json}'",
    "format:fix": "prettier --write --ignore-path .gitignore '**/*.{js,mjs,ts,tsx,css,scss,json}'",
    "lint:check": "eslint .",
    "lint:fix": "eslint --fix",
    "type:check": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:update-snapshot": "vitest run -u",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "storybook:dev": "storybook dev -p 6006 --no-open --disable-telemetry",
    "storybook:build": "storybook build --disable-telemetry",
    "storybook:test": "test-storybook",
    "storybook:test:ci": "pnpx concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"pnpm run storybook:build --quiet && pnpx http-server storybook-static --port 6006 --silent\" \"pnpx wait-on tcp:6006 && pnpm run storybook:test --browsers firefox chromium\"",
    "postinstall": "flowbite-react patch"
  },
  "engines": {
    "pnpm": "10",
    "node": ">=18"
  },
  "peerDependencies": {
    "flowbite-react": "^0.11.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "react-toastify": "^11.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.2",
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.15.0",
    "@fontsource/poppins": "^5.1.0",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-interactions": "^8.4.7",
    "@storybook/addon-onboarding": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@storybook/test": "^8.4.7",
    "@storybook/test-runner": "^0.24.0",
    "@tailwindcss/vite": "^4.1.11",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/lodash": "^4.17.13",
    "@types/node": "^24.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "eslint-plugin-storybook": "^0.12.0",
    "fast-xml-parser": "^5.2.5",
    "globals": "^17.0.0",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.0.0",
    "lodash": "^4.17.21",
    "playwright": "1.59.1",
    "prettier": "3.8.3",
    "rollup-preserve-directives": "^1.1.3",
    "storybook": "^8.4.7",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.15.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vite-plugin-lib-inject-css": "^2.1.1",
    "vitest": "^3.0.0",
    "zod": "^3.24.1"
  }
}
